generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  company   String?
  reason    String
  message   String
  createdAt DateTime @default(now())
}
